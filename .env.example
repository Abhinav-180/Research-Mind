# ==============================================================================
# ResearchMind Environment Configuration Template
# Copy this file to '.env' and fill in your keys.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. SEARCH TOOL CONFIGURATION (Tavily)
# ------------------------------------------------------------------------------
# Tavily offers 1,000 FREE search queries per month.
# Sign up at https://tavily.com to get your free API key.
TAVILY_API_KEY=your_free_tavily_api_key_here

# ------------------------------------------------------------------------------
# 2. FREE LLM MODEL CONFIGURATION (OpenRouter)
# ------------------------------------------------------------------------------
# OpenRouter offers completely free access to models like Gemma 2, Llama 3, etc.
# 1. Sign up at https://openrouter.ai (no credit card required).
# 2. Go to Keys, create a new API key, and paste it below.
OPENROUTER_API_KEY=your_free_openrouter_api_key_here

# (Optional) Override the default free model name.
# Default model: meta-llama/llama-3.3-70b-instruct:free
# Other excellent free models available on OpenRouter:
# - meta-llama/llama-3.2-3b-instruct:free
# - nousresearch/hermes-3-llama-3.1-405b:free
# - cohere/north-mini-code:free
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ------------------------------------------------------------------------------
# 3. ALTERNATIVE: MISTRAL AI CONFIGURATION (Direct API access)
# ------------------------------------------------------------------------------
# If you prefer to bypass OpenRouter and use your Mistral AI key directly:
# 1. Sign up at https://console.mistral.ai
# 2. Add your MISTRAL_API_KEY below.
# 3. Un-comment/set LLM_MODEL to a Mistral model (e.g. mistral-small-latest or mistral-large-latest).
# MISTRAL_API_KEY=your_mistral_api_key_here
# LLM_MODEL=mistral-small-latest


